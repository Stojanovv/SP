#include <iostream>
#include<cstring>
#include<iomanip>
using namespace std;
void pemesto(int a[],int n){
    int temp;
    for (int i = 0; i < n; ++i) {
        if (a[i]<1){
            temp=a[i];
            a[i]=a[n-1];
            a[n-1]=temp;
        }
    }
}
int main() {
   int n;
   cin>>n;
   int niza[100];
    for (int i = 0; i < n; ++i) {
        cin>>niza[i];
    }
    pemesto(niza,n);
    for (int i = 0; i < n; ++i) {
        cout<<niza[i]<<" ";
    }
}
