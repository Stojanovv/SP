#include <iostream>
#include<cstring>
#include<iomanip>
using namespace std;
int par(int a[],int n){
    int min=1000;int counter=0,counter1=0;
    for (int i = 0; i < n; ++i) {
        counter=0;
        for (int j = 0; j < n; ++j) {
            if (a[i]==a[j]){
                counter++;
            }
        }
        if (counter%2==0){
            if (a[i]<min){
                min=a[i];
                counter1++;
            }
        }
    }
    if(counter1>0) {
        return min;
    }else{
        return 0;
    }
}

int main() {
   int n;
   cin>>n;
   int niza[100];
    for (int i = 0; i < n; ++i) {
        cin>>niza[i];
    }
    if (par(niza,n)!=0){
    cout<<"Najmaliot element koj se pojavuva paren broj pati e "<<par(niza,n);
    }else {
        cout<<"Nitu eden element ne se pojavuva paren broj pati!";
    }
    return 0;
}
