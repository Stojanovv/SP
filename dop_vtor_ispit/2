#include <iostream>
#include<cmath>

using namespace std;

int main() {
    int N;
    cin>>N;
    int n;
    n=(int ) ceil(sqrt(N));
    int mat[n][n];int popolni=1;
    for (int j = 0; j < n; ++j) {
        if (j%2==0){
            for (int i = 0; i <n ; ++i) {
                mat[i][j]=popolni;
                popolni++;
                if (popolni>N+1){
                    mat[i][j]=0;
                }
            }
        }else if (j%2==1){
            for (int i = n-1; i >=0 ; --i) {
                mat[i][j]=popolni;
                popolni++;
                if (popolni>N+1){
                    mat[i][j]=0;
                }
            }
        }
    }
    for (int i = 0; i < n; ++i) {
        for (int j = 0; j < n; ++j) {
            cout<<mat[i][j]<<" ";
        }
        cout<<endl;
    }
    return 0;
}
