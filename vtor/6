#include <iostream>
#include<cstring>
#include<iomanip>
using namespace std;

int main(){
    int n,m;
    cin>>n>>m;
    int mat[100][100];
    for (int i = 0; i < n; ++i) {
        for (int j = 0; j < m; ++j) {
            cin>>mat[i][j];
        }
    }
    int counter=0;
    for (int i = 0; i < n; ++i) {
        for (int j = 0; j < m-2; ++j) {
            if (mat[i][j]==1 && mat[i][j+1]==1 && mat[i][j+2]==1) {
                counter++;
                break;
            }
        }
    }
    for (int j = 0; j < m; ++j) {
        for (int i = 0; i < n; ++i) {
            if (mat[i][j]==1 && mat[i+1][j]==1 && mat[i+2][j]==1) {
                counter++;
                break;
            }
        }
    }
    cout<<counter;
 }
 
