#include <iostream>
#include<iomanip>
#include<cstring>
#include<vector>
using namespace std;

int main() {
    char z1,z2;
    cin>>z1>>z2;
    cin.get();
    char niza[80];
    while (cin.getline(niza,80)){
        if (niza[0]=='#') break;
        else
        {
            int dolzina= strlen(niza);
            int prv,posleden;
            for (int i = 0; i < dolzina; ++i) {
                if (niza[i] == z1) {
                    prv = i;
                    break;
                }
            }
            for (int i = 0; i < dolzina; ++i) {
                
            
                if (niza[i]==z2){
                    posleden=i;
                    break;
                }
            }
            for (int i = prv+1; i < posleden ; ++i) {
                cout<<niza[i];
            }
            cout<<endl;
        }
    }

}
