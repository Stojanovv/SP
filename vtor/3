#include <iostream>
#include<iomanip>
#include<vector>
using namespace std;
int sum_pos(int niza[100],int ind,int n){
    if (ind>n) return 0;
    int suma=0;
    for (int i = ind; i <n ; ++i) {
        
         suma+=niza[i];
        

    }
    return suma;
}

int main() {
    int  n;
    cin>>n;
    int niza[n];
    for (int i = 0; i < n; ++i) {
        cin>>niza[i];
        
    }
    int ind;
    cin>>ind;
    cout<<sum_pos(niza,ind,n);
    return 0;
}
