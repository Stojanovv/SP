#include <iostream>
#include<cstring>
using namespace std;
void sort(char niza[],int n){
    for (int i = 0; i < n-1; ++i) {
        for (int j = 0; j < n-1-i; ++j) {
            if (niza[j]>niza[j+1]){
                char temp=niza[j];
                niza[j]=niza[j+1];
                niza[j+1]=temp;
            }
        }
    }
}
int main(){
    char niza[100];

    int counter=0;
    int temp;
    while (cin.getline(niza,100)){
        char redica[100];
        counter=0;
        if (niza[0]=='#') break;
        int j=0;
        for (int i = 0; i < strlen(niza); ++i) {
            if (isdigit(niza[i])){
                counter++;
                redica[j]=niza[i];
                j++;
            }
        }

        cout<<counter<<":";
        sort(redica,j);
        for(int i=0;i<counter;i++){
            cout<<redica[i];
        }
        cout<<endl;



    }
}
