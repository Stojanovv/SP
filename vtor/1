int main() {
    int counter=0;
    char niza[100];
    while(cin.getline(niza,100)){
        for (int i = 0; i < strlen(niza); ++i) {
            if (samoglaska(niza[i])){
                switch(niza[i]){
                    case 'A':
                        niza[i]='a';
                        break;
                    case 'E':
                        niza[i]='e';
                        break;
                    case 'I':
                        niza[i]='i';
                        break;
                    case 'O':
                        niza[i]='o';
                        break;
                    case 'U':
                        niza[i]='u';
                        break;

                }
                if (samoglaska(niza[i+1])){
                    switch(niza[i+1]){
                        case 'A':
                            niza[i+1]='a';
                            break;
                        case 'E':
                            niza[i+1]='e';
                            break;
                        case 'I':
                            niza[i+1]='i';
                            break;
                        case 'O':
                            niza[i+1]='o';
                            break;
                        case 'U':
                            niza[i+1]='u';
                            break;

                    }
                    cout<<niza[i]<<niza[i+1]<<endl;
                    counter++;
                }
            }
        }
        
    }
