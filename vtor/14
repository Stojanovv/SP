#include <iostream>
#include<iomanip>
#include<cstring>
using namespace std;

int main() {
    int n;
    cin>>n;
    int mat[50][50],b[50][50];
    for (int i = 0; i < n; ++i) {
        for (int j = 0; j < n*2; ++j) {
            cin>>mat[i][j];
        }
    }
    for (int i = 0; i < n; ++i) {
        for (int j = 0; j < n; ++j) {
            b[i][j]=mat[i][j];
            b[i+n][j]=mat[i][j+n];
            
        }
        
    }
    for (int i = 0; i < n*2; ++i) {
        for (int j = 0; j < n; ++j) {
            cout<<b[i][j]<<" ";
            
        }
        cout<<endl;
    }
}
