#include <iostream>
#include<cstring>
#include<iomanip>
using namespace std;

int main(){
int n;
cin>>n;
float mat[100][100];
    for (int i = 0; i < n; ++i) {
        for (int j = 0; j < n; ++j) {
            cin>>mat[i][j];
        }
    }
    float x=0,y=0;
    float b[100][100];
    for (int i = 0; i < n; ++i) {
        for (int j = 0; j < n; ++j) {
            if (i>j){
                x+=mat[i][j];
            }
            if (i+j>n-1){
                y+=mat[i][j];
            }
        }
    }
    for (int i = 0; i < n; ++i) {
        for (int j = 0; j < n; ++j) {
            if (i==j && i+j==n-1){
                b[i][j]=x+y;
            }
            else if (i==j){
                b[i][j]=x;
            }else if (i+j==n-1){
                b[i][j]=y;
            }else{
                b[i][j]=0;
            }
        }
    }
    for (int i = 0; i < n; ++i) {
        for (int j = 0; j < n; ++j) {
            cout<<b[i][j]<<" ";
        }
        cout<<endl;
    }
 }
