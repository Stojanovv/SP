#include<iostream>
using namespace std;

int main() {
    int n;
    cin>>n;
    int niza[n][n];
    for (int i = 0; i < n; ++i) {
        for (int j = 0; j < n; ++j) {
            cin>>niza[i][j];
        }
    }
    for (int i = 0; i < n; ++i) {
        for (int j = 0; j < n; ++j) {
            int suma=0;
            if (niza[i][j]<0){
                 if(i==0&&j==0){
                    suma=niza[i+1][j]+niza[i][j+1];
                }
                else if(j==0&&i==n-1){
                    suma=niza[i-1][j]+niza[i][j+1];
                }
                 else if (i==0&&j==n-1){
                    suma=niza[i+1][j]+niza[i][j-1];
                }
                else if (j==n-1&&i==n-1){
                    suma=niza[i-1][j]+niza[i][j-1];
                }
                else if (i==0){
                    suma=niza[i+1][j]+niza[i][j+1]+niza[i][j-1];
                } 
               else if(j==0){
                    suma=niza[i+1][j]+niza[i-1][j]+niza[i][j-1];
                } else if (i==n-1){
                    suma=niza[i-1][j]+niza[i][j+1]+niza[i][j-1];
                }else if(j==n-1){
                    suma=niza[i+1][j]+niza[i-1][j]+niza[i][j-1];
                }
                else{
                    suma=niza[i+1][j]+niza[i-1][j]+niza[i][j+1]+niza[i][j-1];
                }
                niza[i][j]=suma;
            }
        }
    }
    for (int i = 0; i < n; ++i) {
        for (int j = 0; j < n; ++j) {
            cout<<niza[i][j]<<" ";
        }
        cout<<endl;
    }

}
