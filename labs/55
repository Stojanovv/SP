#include <iostream>
#include<iomanip>
#include<vector>
#include<algorithm>

using namespace std;


int main() {
    int n;
    cin>>n;
    int mat[n][n];
    for (int i = 0; i < n; ++i) {
        for (int j = 0; j < n; ++j) {
            cin >> mat[i][j];
        }
    }
    int min=1000;
    for (int i = 0; i < n; i++) {

        if(i%2==0){
            min=1000;
            for (int j = 0; j < n; ++j) {
                if (mat[i][j]<min){
                    min=mat[i][j];
                }
            }
        }
        else if (i%2==1){
            for (int j = 0; j < n; ++j) {
                mat[i][j]+=min;
            }
        }


    }
    for (int i = 0; i < n; ++i) {
        for (int j = 0; j < n; ++j) {
            cout<<mat[i][j]<<" ";
        }
        cout<<endl;
    }
}
