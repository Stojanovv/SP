#include <iostream>
#include<iomanip>
#include<vector>
using namespace std;


int main() {
    int n,najgolem=0,najmal=100;
    cin>>n;
    int a[100];
    for (int i = 0; i < n; ++i) {
        cin>>a[i];
        if (a[i]>najgolem) {najgolem=a[i];}
        if (a[i]<najmal){
            najmal=a[i];
        }


    }
    for (int i = 0; i < n; ++i) {
        a[i]+=(najgolem-najmal);

    }
    cout<<"MAX ->"<<" "<<najgolem<<endl;
    cout<<"MIN ->"<<" "<< najmal <<endl;
    for (int i = 0; i < n; ++i) {
        cout<<a[i]<<" ";

    }


    return 0;
}
