#include<iostream>
using namespace std;

int main() {
    int n,suma=0;
    float prosek=0.0;
    cin>>n;
    int niza[n][n];
    for (int i = 0; i < n; ++i) {
        for (int j = 0; j < n; ++j) {
            cin>>niza[i][j];
        }
    }
    for (int i = 0; i < n; ++i) {
        float suma = 0.0;
        int c=0;
        for (int j = 0; j < n; ++j) {
            if(i+j==n-1)continue;
            else if (i+j<n-1){
                suma+=niza[i][j];
                c++;
            }
            else if (i+j>n-1){
                prosek=suma/c;
                if (niza[i][j]<prosek){
                    niza[i][j]=-1;
                }
            }
        }
    }
    for (int i = 0; i < n; ++i) {
        for (int j = 0; j < n; ++j) {
            cout<<niza[i][j]<<" ";
        }
        cout<<endl;
    }

}
