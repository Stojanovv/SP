#include <iostream>
#include<iomanip>
#include<vector>
#include<algorithm>

using namespace std;


int main() {
    int n;
    cin>>n;
    int mat[n][n];
    for (int i = 0; i < n; ++i) {
        for (int j = 0; j < n; ++j) {
            cin >> mat[i][j];
        }
    }
    int suma=0;
    for (int i = 0; i < n; ++i) {
        for (int j = 0; j < n; ++j) {
            suma=0;
            if (mat[i][j]<0) {
                if ( i == 0 && j == 0) {
                    suma = mat[i + 1][j] + mat[i][j - 1];
                } else if (  j == n - 1 && i == n - 1) {
                    suma = mat[i - 1][j] + mat[i][j - 1];
                }
                else if (i==0&&j==n-1) {
                    suma = mat[i+1][j]+mat[i][j-1];
                }
                else if (i==n-1 && j==0){
                    suma=mat[i-1][j]+mat[i][j+1];
                }
                else if ( i == n - 1) {
                        suma = mat[i - 1][j] + mat[i][j+1]+ mat[i][j - 1];
                    }
                 else if (j == n - 1) {
                    suma =  mat[i - 1][j] + mat[i][j - 1]+ mat[i+1][j];
                } else if ( i == 0) {
                    suma = mat[i + 1][j]  +mat[i][j-1]+ mat[i][j + 1];
                } else if ( j == 0) {
                    suma = mat[i + 1][j] + mat[i-1][j ] + mat[i][j - 1];
                } else {
                    suma = mat[i + 1][j] + mat[i - 1][j] + mat[i][j + 1] + mat[i][j - 1];
                }
                mat[i][j]=suma;
            }
        }
    }
    for (int i = 0; i < n; ++i) {
        for (int j = 0; j < n; ++j) {
            cout<<mat[i][j]<<" ";
        }
        cout<<endl;
    }
}
