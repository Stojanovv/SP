#include<iostream>
using namespace std;

int main() {
    int n,suma=0,maks=0,id;
    cin>>n;
    int niza[n][n];
    for (int i = 0; i < n; ++i) {
        for (int j = 0; j < n; ++j) {
            cin>>niza[i][j];
        }
    }
    for (int i = 0; i < n; ++i) {
        suma=0;
        for (int j = 0; j < n; ++j) {
            suma+=niza[j][i];
        }
        if (suma>maks){
            maks=suma;
            id=i;
        }
    }
    for (int i = 0; i < n; ++i) {
        niza[i][id]+=maks;
    }
    for (int i = 0; i < n; ++i) {
        for (int j = 0; j < n; ++j) {
            cout<<niza[i][j]<<" ";
        }
        cout<<endl;
    }
}
