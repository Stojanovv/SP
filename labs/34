#include <iostream>
#include<iomanip>
using namespace std;


int main() {
    int n;
    cin>>n;
    int a[n];
    for (int i = 0; i < n; ++i) {
        cin >> a[i];
        if (i%2==0) a[i]*=2;
        else
            a[i]+=2;

    }
    for (int i = 0; i < n; ++i) {
        cout<<a[i]<<" ";
        
    }

    return 0;
}
