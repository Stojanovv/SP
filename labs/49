#include<iostream>
using namespace std;

int main() {
    int n,m,najgolem=0;
    float prosek=0.0,suma=0;
    cin>>n>>m;
    int niza[n][m];
    for (int i = 0; i < n; ++i) {
        for (int j = 0; j < m; ++j) {
            cin>>niza[i][j];
        }
    }
    for (int i = 0; i < n; ++i) {
        najgolem=0;
        for (int j = 0; j < m; ++j) {
            if (niza[i][j]>najgolem){
                najgolem=niza[i][j];
            }
        }
        niza[i][m-1]=najgolem;
        for (int j = 0; j < m; ++j) {
            suma+=niza[i][j];
        }
    }
    prosek=suma/(n*m);
    for (int i = 0; i < n; ++i) {
        for (int j = 0; j < m; ++j) {
            cout<<niza[i][j]<<" ";
        }
        cout<<endl;
    }
    cout<<prosek;
}
