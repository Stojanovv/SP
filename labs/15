#include <iostream>
#include<cmath>
#include<iomanip>
using namespace std;


int main() {
   int n;
   cin>>n;
   float mat[100][100];
    for (int i = 0; i < n; ++i) {
        for (int j = 0; j < n; ++j) {
            cin>>mat[i][j];
        }
    }
    float min,max;
    for (int j = 0; j < n; ++j) {
        min=1000;max=0;
        for (int i = 0; i < n; ++i) {
            if (mat[i][j]<min){
                min=mat[i][j];
            }
            else if (mat[i][j]>max){
                max=mat[i][j];
            }
        }
        for (int i = 0; i < n; ++i) {
            mat[i][j]=(mat[i][j]-min)/(max-min);
        }
    }
    for (int i = 0; i < n; ++i) {
        for (int j = 0; j < n; ++j) {
            cout<<mat[i][j]<<" ";
        }
        cout<<endl;
    }


    return 0;
}
