#include<iostream>
using namespace std;

int main() {
    int n,m;
    cin>>n>>m;
    bool tocna;
    int niza[n][n];
    for (int i = 0; i < n; ++i) {
        for (int j = 0; j < m; ++j) {
            cin>>niza[i][j];
        }
    }
    for (int i = 0; i < n; ++i) {
        for (int j = 0; j < m; ++j) {
            if (i!=j){
                if (niza[i][j]==niza[j][i]) {
                    tocna = true;
                    //continue;
                }
                    else{
                    tocna=false;
                    //break;
                    }
            }
        }
        //if(tocna==false) break;
    }
    if(tocna) cout<<"1"<<endl;
    else cout<<"-1"<<endl;
    for (int i = 0; i < n; ++i) {
        for (int j = 0; j < m; ++j) {
            cout<<niza[i][j]<<" ";
        }
        cout<<endl;
    }

}
