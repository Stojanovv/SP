#include<iostream>
using namespace std;

int main() {
    int n;
    cin>>n;
    int niza[n][n];
    for (int i = 0; i < n; ++i) {
        for (int j = 0; j < n; ++j) {
            cin>>niza[i][j];
        }
    }
    for (int i = 0; i < n; ++i) {
        for (int j = 0; j < n; ++j) {
            if (i>j && i+j>n-1){
                niza[i][j]*=-1;
            }
        }
    }
    for (int i = 0; i < n; ++i) {
        for (int j = 0; j < n; ++j) {
            cout<<niza[i][j]<<" ";
        }
        cout<<endl;
    }

}
