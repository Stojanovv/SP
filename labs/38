#include <iostream>
#include<iomanip>
using namespace std;


int main() {
    int n;
    float prosek,suma=0.0;
    cin>>n;
    int a[n];
    for (int i = 0; i < n; ++i) {
        cin >> a[i];
    }
    for (int i = 0; i < n; ++i) {
        suma+=a[i];

    }
    prosek=suma/n;
    for (int i = 0; i < n; ++i) {
        if (a[i]<prosek)
            a[i]=0;
        else
            a[i]=1;

    }
    cout<<"Average price:"<<" " <<prosek<<endl;
    for (int i = 0; i < n; ++i) {
        cout<<a[i]<<" ";
        
        
    }


    return 0;
}
