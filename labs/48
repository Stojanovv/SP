#include <iostream>
#include<cmath>
#include<iomanip>
using namespace std;

int main() {
   int n,m;
   cin>>n>>m;
   int mat[100][100];
    for (int i = 0; i < n; ++i) {
        for (int j = 0; j < m; ++j) {
            cin>>mat[i][j];
        }
    }
    if (n==m) {
        for (int i = 0; i < n; ++i) {
            int r = 0;
            int k = i;
            while (r < n && k >= 0) {
                cout << mat[r][k] << " ";
                r++;
                k--;
            }
            cout << endl;
        }
    }
    if (n!=m){
        for (int i = 0; i < n; ++i) {
            int r = 0;
            int k = i;
            while (r < n && k >= 0) {
                cout << mat[r][k] << " ";
                r++;
                k--;
            }
            cout << endl;
        }
        for (int i = 0; i < n; ++i) {
            int r=i; int k=m-1;
            while (r<n && m>=k){
                cout << mat[r][k] << " ";
                r++;
                k--;
            }cout<<endl;
        }
    }
    return 0;
}
