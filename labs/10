#include <iostream>
#include<iomanip>
bool sporedi(int matrica[100][100],int matrica2[100][100],int n,int m){
    int tocna=false;
    for (int j = 0; j < n; ++j) {
        for (int i = 0; i < m; ++i) {
            j=0;
            for (int k = 0; k < m; ++k) {
                for (int l = 0; l < n; ++l) {
                    if (matrica[i][j]==matrica2[l][k]){
                        j++;
                        tocna=true;
                        continue;
                    }else{
                        tocna=false;
                        break;
                }
                }
            }
        }
    }
    return tocna;
}
using namespace std;
int main() {
    int n, m;
    cin >> n >> m;
    int mat1[100][100], mat2[100][100];
    for (int i = 0; i < n; ++i) {
        for (int j = 0; j < m; ++j) {
            cin >> mat1[i][j];
        }
    }
    for (int i = 0; i < n; ++i) {
        for (int j = 0; j < m; ++j) {
            cin >> mat2[i][j];
        }
    }
    int counter = 0;
    if (sporedi(mat1, mat2, n, m)) counter++;
    cout << counter;
    return 0;
}
