#include <iostream>
#include<iomanip>
#include<vector>
#include<cstring>

using namespace std;

int main() {
   int n;
   cin>>n;
   int mat[100][100];
   for(int i=0;i<n;i++){
       for(int j=0;j<n;j++){
           cin>>mat[i][j];
       }
   }
   int dijagonala[n];
   int y;
   cin>>y;
    for (int i = 0; i < n; ++i) {
        for (int j = 0; j < n; ++j) {
            if (i==j){
                dijagonala[i]=mat[i][j];
                mat[i][j]=mat[i][y];
            }
        }
        mat[i][y]=dijagonala[i];
        mat[y][i]=dijagonala[i];
    }

    for (int i = 0; i < n; ++i) {
        for (int j = 0; j < n; ++j) {
            cout<<mat[i][j]<<" ";
        }
        cout<<endl;
    }
}
